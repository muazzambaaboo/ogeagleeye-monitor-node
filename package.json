{
  "name": "@ogeagleeye/monitor-node",
  "version": "0.2.0",
  "description": "OGEagleEye monitoring SDK for Node.js (plain + Express)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/@ogeagleeye/monitor-node",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muazzambaaboo/ogeagleeye-monitor-node.git"
  },
  "bugs": {
    "url": "https://github.com/muazzambaaboo/ogeagleeye-monitor-node/issues"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.30",
    "@types/supertest": "^6.0.3",
    "express": "^4.21.2",
    "supertest": "^7.1.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
